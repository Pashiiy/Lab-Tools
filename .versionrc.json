{
  "header": "# Changelog\n\nAll notable changes to Lab Tools are documented here.\nThe format follows [Keep a Changelog](https://keepachangelog.com/) and [Semantic Versioning](https://semver.org/).\n\nConventional commit types for version bumps:\n- `fix:` → patch\n- `feat:` → minor\n- `BREAKING CHANGE:` or `feat!:` → major\n",
  "types": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance Improvements" },
    { "type": "revert", "section": "Reverts" },
    { "type": "docs", "section": "Documentation", "hidden": true },
    { "type": "style", "hidden": true },
    { "type": "chore", "hidden": true },
    { "type": "refactor", "hidden": true },
    { "type": "test", "hidden": true },
    { "type": "build", "hidden": true },
    { "type": "ci", "hidden": true }
  ],
  "releaseCommitMessageFormat": "chore(release): {{currentTag}}",
  "bumpFiles": [
    { "filename": "package.json", "type": "json" },
    { "filename": "package-lock.json", "type": "json" }
  ],
  "packageFiles": [
    { "filename": "package.json", "type": "json" },
    { "filename": "package-lock.json", "type": "json" }
  ]
}

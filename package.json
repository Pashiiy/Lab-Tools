{
  "name": "lab-tools",
  "private": true,
  "version": "1.1.5",
  "description": "Lab Tools — endpoint analysis, colony counting, gel quantification, and qPCR analysis for microbiology labs",
  "author": "Bloom Lab",
  "type": "module",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pashiiy/Lab-Tools.git"
  },
  "homepage": "https://github.com/Pashiiy/Lab-Tools",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-icons": "node scripts/generate-icons.mjs",
    "predist": "npm run generate-icons",
    "predist:win": "npm run generate-icons",
    "predist:mac": "npm run generate-icons",
    "predist:all": "npm run generate-icons",
    "dist": "npm run build && electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --publish never",
    "dist:all": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --win --publish never",
    "verify:mac": "bash scripts/verify-mac.sh",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build:mac": "npm run build && npm run dist:mac",
    "electron:build:win": "npm run build && npm run dist:win",
    "electron:build:all": "npm run dist:all",
    "release": "standard-version && git push --follow-tags origin main"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "geotiff": "^3.0.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "utif": "^3.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.2",
    "standard-version": "^9.5.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.labtools.app",
    "productName": "Lab Tools",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "electron/**/*"
    ],
    "publish": {
      "provider": "github",
      "publishAutoUpdate": false
    },
    "mac": {
      "category": "public.app-category.medical",
      "icon": "public/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "identity": "-",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "notarize": false,
      "electronLanguages": [
        "en"
      ],
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "writeUpdateInfo": false
    },
    "win": {
      "icon": "public/icon.ico",
      "target": "nsis",
      "artifactName": "${name}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico"
    }
  }
}

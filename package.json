{
  "name": "lab-tools",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-icons": "node scripts/generate-icons.mjs",
    "preelectron:build:mac": "npm run generate-icons",
    "preelectron:build:win": "npm run generate-icons",
    "preelectron:build:all": "npm run generate-icons",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build:mac": "npm run build && electron-builder --mac --config.directories.output=release/mac",
    "electron:build:win": "npm run build && electron-builder --win --config.directories.output=release/win",
    "electron:build:all": "npm run build && electron-builder --mac --config.directories.output=release/mac && electron-builder --win --config.directories.output=release/win"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "geotiff": "^3.0.5",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.labtools.app",
    "productName": "Lab Tools",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "electron/**/*",
      "!electron/**/*.map",
      "!**/.git/**",
      "!**/.vite/**",
      "!**/node_modules/**",
      "!src/**",
      "!scripts/**"
    ],
    "mac": {
      "category": "public.app-category.medical",
      "icon": "public/icon.icns",
      "target": "dmg",
      "electronLanguages": [
        "en"
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "public/icon.ico",
      "target": "nsis",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico"
    }
  }
}
